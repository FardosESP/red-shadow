# Ambani Integration - Environment Variables Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# AMBANI CONFIGURATION
# ============================================================================

# Enable/disable Ambani integration
AMBANI_ENABLED=true

# Path to Ambani API
AMBANI_API_PATH=/path/to/ambani/api

# Enable safe mode (prevents destructive operations)
AMBANI_SAFE_MODE=true

# Enable dry-run mode (simulates operations without executing)
AMBANI_DRY_RUN=false

# Rate limit for Ambani operations (events per second)
AMBANI_RATE_LIMIT=5

# Path to configuration file (optional, defaults to config.json)
# AMBANI_CONFIG_PATH=./config.json

# ============================================================================
# AUTO-STOP ENGINE CONFIGURATION
# ============================================================================

# Auto-stop mode: manual, notify, or auto
AUTO_STOP_MODE=notify

# Critical threshold for auto-stop (0-100)
AUTO_STOP_THRESHOLD=85

# Enable learning mode (adjusts thresholds based on feedback)
AUTO_STOP_LEARNING=true

# ============================================================================
# MACHINE LEARNING CONFIGURATION
# ============================================================================

# Enable ML-based analysis
ML_ENABLED=true

# Path to ML training data
ML_TRAINING_PATH=./data/training

# ============================================================================
# NETWORK MONITORING CONFIGURATION
# ============================================================================

# Enable network monitoring
NETWORK_MONITOR_ENABLED=true

# Network interface to monitor (e.g., eth0, wlan0, ens33)
NETWORK_INTERFACE=eth0

# ============================================================================
# MEMORY FORENSICS CONFIGURATION
# ============================================================================

# Enable memory forensics
MEMORY_FORENSICS_ENABLED=true

# ============================================================================
# REPORTING CONFIGURATION
# ============================================================================

# Output directory for reports
REPORT_OUTPUT_DIR=./reports

# Webhook URL for notifications (optional)
# REPORT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/ambani_integration.log

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database file path (SQLite)
DATABASE_PATH=./data/ambani_integration.db

# Database connection string (optional, for external databases)
# DATABASE_CONNECTION_STRING=postgresql://user:pass@localhost/dbname

# ============================================================================
# DEPLOYMENT EXAMPLES
# ============================================================================

# Example 1: Production deployment with auto-stop enabled
# AMBANI_SAFE_MODE=true
# AUTO_STOP_MODE=auto
# LOG_LEVEL=WARNING
# REPORT_WEBHOOK_URL=https://your-webhook-url

# Example 2: Development/testing environment
# AMBANI_DRY_RUN=true
# AUTO_STOP_MODE=manual
# LOG_LEVEL=DEBUG

# Example 3: High-security environment
# AMBANI_SAFE_MODE=true
# AUTO_STOP_MODE=notify
# AUTO_STOP_THRESHOLD=70
# ML_ENABLED=true
# NETWORK_MONITOR_ENABLED=true
# MEMORY_FORENSICS_ENABLED=true
